# name: test_error_message[class_inheritance.py]
  '''
  class_inheritance.py:6:1: error: a base class is not supported
  
    6 | class Square(Shape):
      | ^^^^^^^^^^^^^^^^^^^^
  
    help: give the class its own copy of what it needs:
            class Square:
                def __init__(self, side: int) -> None:
                    self.side = side
  
  '''
# ---
# name: test_error_message[class_variable.py]
  '''
  class_variable.py:2:5: error: a class level value is not supported
  
    2 |     kind: str = "point"
      |     ^^^^^^^^^^^^^^^^^^^
  
    help: every attribute is per instance, so set it in __init__:
            def __init__(self) -> None:
                self.kind = "point"
  
  '''
# ---
# name: test_error_message[dict_unpacking.py]
  '''
  dict_unpacking.py:3:14: error: `**` unpacking in a dict literal is not supported
  
    3 |     merged = {**base, "b": 2}
      |              ^^^^^^^^^^^^^^^^
  
    help: copy the entries across in a loop:
            merged = {"a": 1}
            for key in other:
                merged[key] = other[key]
  
  '''
# ---
# name: test_error_message[except_star.py]
  '''
  except_star.py:4:13: error: `except*` groups are not supported
  
    4 |     except* ValueError as error:
      |             ^^^^^^^^^^
  
    help: use a plain except clause:
            except ValueError as error:
  
  '''
# ---
# name: test_error_message[except_tuple.py]
  '''
  except_tuple.py:4:12: error: an except clause takes a single exception class
  
    4 |     except (ValueError, KeyError):
      |            ^^^^^^^^^^^^^^^^^^^^^^
  
    help: write one clause per class:
            except ValueError:
                ...
            except KeyError:
                ...
  
  '''
# ---
# name: test_error_message[exception_arguments.py]
  '''
  exception_arguments.py:2:11: error: an exception takes a single message
  
    2 |     raise ValueError("first", "second")
      |           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  
    help: join the parts into one string:
            raise ValueError("a: " + b)
  
  '''
# ---
# name: test_error_message[generator_expression.py]
  '''
  generator_expression.py:3:16: error: generator expressions are not supported
  
    3 |     total = sum(v * 2 for v in values)
      |                ^^^^^^^^^^^^^^^^^^^^^^^
  
    help: wrap it in a list, which is built in one go rather than lazily:
            total = sum([v * 2 for v in values])
  
  '''
