  '''
  raise_from.py:5:9: error: chaining exceptions with `from` is not supported
  
    5 |         raise KeyError("missing") from error
      |         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  
    help: raise the new exception on its own:
            raise KeyError("missing")
  
  '''
